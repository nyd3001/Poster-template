% Reusable theme layer for tikzposter-based research posters.

\providecommand{\PosterTitleLeftWidth}{0.14\linewidth}
\providecommand{\PosterTitleCenterWidth}{0.68\linewidth}
\providecommand{\PosterTitleRightWidth}{0.14\linewidth}
\providecommand{\PosterTitleFont}{\bfseries \Huge}
\providecommand{\PosterAuthorFont}{\Large}
\providecommand{\PosterInstituteFont}{\large}
\providecommand{\PosterTitleYOffset}{0pt}
\providecommand{\PosterLeftLogoYOffset}{0pt}
\providecommand{\PosterRightLogoYOffset}{0pt}
\providecommand{\PosterTitleAuthorGap}{1em}
\providecommand{\PosterAuthorInstituteGap}{0.8em}
\providecommand{\PosterLeftLogo}{}
\providecommand{\PosterRightLogo}{}
\providecommand{\PosterHighlightColor}{highlightColor}
\providecommand{\PosterRowOneHeight}{12.5in}
\providecommand{\PosterRowTwoHeight}{11.5in}
\providecommand{\PosterContentFontSize}{\fontsize{32pt}{38pt}\selectfont}
\providecommand{\PosterLineStretch}{1.10}
\providecommand{\PosterArrayStretch}{1.15}
\providecommand{\PosterRootPath}{.}
\providecommand{\PosterAssetPath}{.}

\definecolor{SUBlue}{HTML}{8C0000}
\definecolor{highlightColor}{HTML}{8C0000}
\definecolor{SUOliveLeaf}{HTML}{01a2ff}
\definecolor{SUSky}{HTML}{ACDEE6}
\definecolor{SUWater}{HTML}{9BB2CE}
\definecolor{SUFire}{HTML}{D95E00}
\definecolor{Cyan}{HTML}{00aeef}
\definecolor{SkyBlue}{HTML}{41b6e6}
\definecolor{Teal}{HTML}{487f84}
\definecolor{KellyGreen}{HTML}{348338}
\definecolor{SeaGreen}{HTML}{006c5b}
\definecolor{Olive}{HTML}{5c8118}
\definecolor{Orange}{HTML}{c35413}
\definecolor{Red}{HTML}{da291c}
\definecolor{Magenta}{HTML}{c6007e}
\definecolor{Purple}{HTML}{6558b1}
\definecolor{Grape}{HTML}{6d2077}
\definecolor{Black}{HTML}{101820}
\definecolor{PosterTitleBg}{HTML}{8C0000}
\definecolor{PosterTitleFg}{HTML}{FFFFFF}
\definecolor{CoolGray5}{HTML}{b1b3b3}
\definecolor{CoolGray2}{HTML}{d0d0ce}
\definecolor{CoolGray1}{HTML}{d9d9d9}
\definecolor{LightYellow}{HTML}{ffde75}

\definecolorpalette{SUPalette} {
    \definecolor{colorOne}{named}{SUBlue}
    \definecolor{colorTwo}{named}{SUBlue}
    \definecolor{colorThree}{named}{SUBlue}
}

\definecolorstyle{SUStyle} {
    \usecolorpalette{SUPalette}
}{
    \colorlet{backgroundcolor}{white}
    \colorlet{framecolor}{white}
    \colorlet{titlefgcolor}{PosterTitleFg}
    \colorlet{titlebgcolor}{PosterTitleBg}
    \colorlet{blocktitlebgcolor}{colorOne}
    \colorlet{blocktitlefgcolor}{white}
    \colorlet{blockbodybgcolor}{white}
    \colorlet{blockbodyfgcolor}{Black}
    \colorlet{innerblocktitlebgcolor}{white}
    \colorlet{innerblocktitlefgcolor}{Black}
    \colorlet{innerblockbodybgcolor}{colorTwo}
    \colorlet{innerblockbodyfgcolor}{Black}
    \colorlet{notefgcolor}{Black}
    \colorlet{notebgcolor}{colorTwo}
    \colorlet{noteframecolor}{colorTwo}
}

\definebackgroundstyle{SUBackgroundStyle}{
    \draw[line width=0pt, color=framecolor, fill=backgroundcolor]
    (bottomleft) rectangle (topright);
}

\definetitlestyle{SUTitleStyle}{
    width=\textwidth, roundedcorners=0, linewidth=0pt, innersep=1.5cm,
    titletotopverticalspace=0mm, titletoblockverticalspace=20mm,
    titlegraphictotitledistance=10pt
}{
   \draw[draw=none, fill=titlebgcolor](\titleposleft,\titleposbottom) rectangle (\titleposright,\titlepostop);
}

\defineblockstyle{SUBlockStyle}{
    titlewidthscale=1.0, bodywidthscale=1, roundedcorners=5
}{
    \draw[color=framecolor, fill=blockbodybgcolor,
    rounded corners=\blockroundedcorners] (blockbody.south west)
    rectangle (blockbody.north east);
    \ifBlockHasTitle
    \draw[color=framecolor, fill=blocktitlebgcolor,
    rounded corners=\blockroundedcorners] (blocktitle.south west)
    rectangle (blocktitle.north east);
    \fi
}

\definelayouttheme{SUTheme}{
    \usecolorstyle[colorPalette=SUPalette]{SUStyle}
    \usebackgroundstyle{SUBackgroundStyle}
    \usetitlestyle{SUTitleStyle}
    \useblockstyle{SUBlockStyle}
    \useinnerblockstyle{Default}
    \usenotestyle{Default}
}

\newcommand{\PosterBlock}[3]{%
    \block{#1}{%
        \begin{minipage}[t][#2][t]{\linewidth}
            \vspace*{0pt}%
            #3%
            \par\vfill
        \end{minipage}%
    }%
}

\newcommand{\PosterInputBlock}[3]{\PosterBlock{#1}{#2}{\input{#3}}}
\newcommand{\PosterHighlight}[1]{\textcolor{\PosterHighlightColor}{\textbf{#1}}}
\newcommand{\PosterSmallNote}[1]{{\large\textcolor{CoolGray5}{#1}}}
\newcommand{\PosterApplyTypography}{%
    \usepackage[scaled]{helvet}%
    \renewcommand\familydefault{\sfdefault}%
    \usepackage[T1]{fontenc}%
    \usepackage{setspace}%
    \setstretch{\PosterLineStretch}%
    \renewcommand{\arraystretch}{\PosterArrayStretch}%
}
\makeatletter
\newcommand{\PosterFixColumnAlignment}{%
    \setlength{\TP@innermargin}{0pt}%
    \setlength{\TP@visibletextwidth}{\textwidth}%
}
\newcommand\titlegraphicleft[1]{\def\@titlegraphicleft{#1}}
\titlegraphicleft{}
\renewcommand\TP@maketitle{%
   \centering
   \begin{minipage}[c]{\PosterTitleLeftWidth}
        \centering
        \raisebox{\PosterLeftLogoYOffset}{\@titlegraphicleft}
    \end{minipage}%
    \hfill
   \begin{minipage}[c]{\PosterTitleCenterWidth}
        \centering
        \color{titlefgcolor}
        \raisebox{\PosterTitleYOffset}{%
            \begin{minipage}{\linewidth}
                \centering
                {\PosterTitleFont \@title \par}
                \vspace*{\PosterTitleAuthorGap}
                {\PosterAuthorFont \@author \par}
                \vspace*{\PosterAuthorInstituteGap}
                {\PosterInstituteFont \@institute}
            \end{minipage}%
        }
    \end{minipage}%
    \hfill
    \begin{minipage}[c]{\PosterTitleRightWidth}
        \centering
        \raisebox{\PosterRightLogoYOffset}{\@titlegraphic}
    \end{minipage}%
}
\makeatother
